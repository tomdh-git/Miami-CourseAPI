"""
Generic course query input. The 'filters' field is a school-specific JSON object.
Use getSchoolSchema(school) to discover valid filter keys.
"""
input CourseQueryInput {
    """The school identifier (e.g. 'miami', 'ohiostate')"""
    school: String!

    """
    School-specific query filters as a JSON object.
    Example for miami: { "term": "202510", "campus": ["O"], "subject": ["CSE"] }
    """
    filters: JSON!
}
