"""
A schedule consisting of non-conflicting course sections.
"""
type Schedule {
    courses: [Course!]!
    freeTime: Int!
}

"""
Union result type for schedule queries.
"""
union ScheduleResult = SuccessSchedule | ErrorSchedule

type SuccessSchedule {
    schedules: [Schedule!]!
}

type ErrorSchedule {
    error: String!
    message: String!
}
