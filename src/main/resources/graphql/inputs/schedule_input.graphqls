input ScheduleByCourseInput{
    school: String = "miami"
    delivery: [String]
    courses: [String]
    campus: [String]
    term: String
    optimizeFreeTime: Boolean
    preferredStart: String
    preferredEnd: String
}
input FillerByAttributesInput{
    school: String = "miami"
    delivery: [String]
    attributes: [String]
    courses: [String]
    campus: [String]
    term: String
    preferredStart: String
    preferredEnd: String
}